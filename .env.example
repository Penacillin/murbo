# Murbo vision-provider API keys — copy to `.env` and fill in what you use.
# `.env` is git-ignored; never commit real keys.

# Claude (Anthropic) — provider: claude
ANTHROPIC_API_KEY=

# MiniMax (Anthropic-compatible endpoint) — provider: minimax
MINIMAX_API_KEY=

# OpenAI — provider: openai
OPENAI_API_KEY=
